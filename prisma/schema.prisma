generator client {
  provider     = "prisma-client"
  output       = "../src/database/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum ROLE {
  ADMIN
  STAFF
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  role         ROLE          @default(STAFF)
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  reservations Reservation[]
  payments     Payment[]

  @@map("users")
}

enum SERVICES {
  THAI
  FOOT
  OIL
  HERBAL
}

enum STATUS {
  PENDING
  CONFIRMED
  ARRIVED
  COMPLETE
}

model Reservation {
  id                Int       @id @default(autoincrement())
  customerName      String    @map("customer_name")
  reservationTime   DateTime  @map("reservation_time")
  reservationSize   Int       @map("reservation_size")
  serviceName       SERVICES  @default(THAI) @map("service_name")
  reservationStatus STATUS    @map("reservation_status")
  customerPhone     String    @map("customer_phone")
  user              User      @relation(fields: [createdBy], references: [id])
  createdBy         Int       @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  payments          Payment[]

  @@map("reservations")
}

enum PAYMENTENUM {
  CASH
  TRANSFER
  CREDIT
}

model Payment {
  id            Int         @id @default(autoincrement())
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId Int         @map("reservation_id")
  user          User        @relation(fields: [createdBy], references: [id])
  createdBy     Int         @map("created_by")
  amount        Decimal     @db.Decimal(12, 2)
  method        PAYMENTENUM @default(CASH)
  status        Boolean     @default(false)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("payments")
}
